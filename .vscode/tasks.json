{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "${workspaceFolder}/LibreLinkupDesktop-Unofficial.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run",
      "type": "shell",
      "command": "dotnet",
      "args": ["run", "--project", "src/LibreLinkupDesktop-Unofficial/LibreLinkupDesktop-Unofficial.csproj"],
      "problemMatcher": []
    }
  ]
}
